import { Component } from '@angular/core';
import { FormsModule } from '@angular/forms';
@Component({
  selector: 'app-root',
  standalone: true,
  imports: [FormsModule],
  templateUrl: './app.html'
})
export class App {
  m1:number = 0;
  m2:number = 0;
  m3:number = 0;
  total:number = 0;
  average:number = 0;
  calculate(){
    this.total = this.m1 + this.m2 + this.m3;
    this.average = this.total / 3;
  }

}


