import { useState } from "react";
import Diary from "./Diary";

function App() {
  const [entries, setEntries] = useState([]);

  return (
    <div style={{background:"#dff6ff", minHeight:"100vh", textAlign:"center", padding:"30px"}}>
      <h1>My Diary</h1>

      <Diary entries={entries} setEntries={setEntries} />
    </div>
  );
}

export default App;
